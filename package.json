{

  "name": "gestify-pos-kiosco",

  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:icon": "node electron/gen-icon.cjs",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "npm run electron:icon && vite build && electron-builder --win nsis",
    "electron:release": "npm run electron:icon && vite build && electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.577.0",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.gestify.pos-kiosco",
    "productName": "Gestify POS Kiosco",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "julianbrochero",
        "repo": "SISTEMA-KIOSCO_POS"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico"
    }
  }
}
